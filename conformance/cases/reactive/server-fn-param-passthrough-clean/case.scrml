${
    <price> = 10
    const <total> = @price * 3
    function saveOrder(total:number) : number {
        result = ?{`INSERT INTO orders (amount) VALUES (${total}) RETURNING id`}
        return result
    }
}
<button id="save" onclick=@price = saveOrder(@total)>Save</>
<p id="t">Total: ${@total}</>
