${ type Health:enum = { Healthy, AtRisk } }
${ type Mood:enum = { Calm, Tense } }
<engine for=Health derived=match @mood {
  .Calm :> .Healthy
  .Tense :> .AtRisk
}>
  <Healthy/>
  <AtRisk/>
</>
<engine for=Mood derived=match @health {
  .Healthy :> .Calm
  .AtRisk :> .Tense
}>
  <Calm/>
  <Tense/>
</>
<p>x</>
