${ type Mario:enum = { Small, Big } }
${ type Health:enum = { Healthy, AtRisk } }
${ type Mood:enum = { Calm, Tense } }
<marioState>: Mario = .Small
<engine for=Health derived=match @marioState {
  .Small :> .Healthy
  .Big :> .AtRisk
}>
  <Healthy/>
  <AtRisk/>
</>
<engine for=Mood derived=match @health {
  .Healthy :> .Calm
  .AtRisk :> .Tense
}>
  <Calm/>
  <Tense/>
</>
<p>x</>
