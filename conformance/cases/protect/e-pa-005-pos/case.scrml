<program>
  <schema>
    ?{`CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, passwordHash TEXT)`}
  </schema>
  <db src="app.db" protect="passwordHash">
    ${
      function getUser(id) {
        return ?{`SELECT id, name FROM users WHERE id = ${id}`}.get()
      }
    }
  </db>
  <div><p>hi</p></div>
</program>
