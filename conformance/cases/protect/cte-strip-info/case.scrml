<program>
  <schema>
    ?{`CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, passwordHash TEXT)`}
  </schema>
  <db src="app.db" protect="passwordHash" tables="users">
    ${
      function getUser(id) {
        return ?{`WITH t AS (SELECT * FROM users WHERE id = ${id}) SELECT * FROM t`}.get()
      }
    }
  </db>
  <div><p>hi</p></div>
</program>
