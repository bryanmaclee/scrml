${
  import { schemaFor } from 'scrml:data'

  type User:struct = {
    email:  string req length(<=120) pattern(/^[^@]+@[^@]+$/)
    name:   string req length(>=2, <=80)
    age:    integer min(0)
    active: boolean req
  }
}
<program db="./db.sqlite">
  <schema>
    ${ schemaFor(User) }
  </>
</program>
