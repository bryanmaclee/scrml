<program db="postgres://localhost/app">

  <schema>
    orders {
      id: int primary key
      status: string
      total: number
    }
  </schema>

  <channel name="orders-feed" watches=orders>
    <onchange>
      <Inserted(row) : print(row)>
      <_> : print("other change")
    </onchange>
  </channel>

</program>
