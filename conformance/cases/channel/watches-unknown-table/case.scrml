<program db="postgres://localhost/app">

  <schema>
    orders {
      id: int primary key
      status: string
      total: number
    }
  </schema>

  <channel name="widgets-feed" watches=widgets>
    <onchange>
      <Inserted(row) : print(row)>
      <Updated(row) : print(row)>
      <Deleted(key) : print(key)>
    </onchange>
  </channel>

</program>
