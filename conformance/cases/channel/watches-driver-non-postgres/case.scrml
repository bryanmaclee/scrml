<program db="sqlite:app.db">

  <schema>
    orders {
      id: integer primary key
      status: text
      total: real
    }
  </schema>

  <channel name="orders-feed" watches=orders>
    <onchange>
      <Inserted(row) : print(row)>
      <Updated(row) : print(row)>
      <Deleted(key) : print(key)>
    </onchange>
  </channel>

</program>
