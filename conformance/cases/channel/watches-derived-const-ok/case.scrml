<program db="postgres://localhost/app">

  <schema>
    orders {
      id: int primary key
      status: string
      total: number
    }
  </schema>

  ${ @maxTotal = 5 }

  <channel name="orders-feed" watches=orders>
    ${ const <threshold> = @maxTotal * 2 }
    <onchange>
      <Inserted(row) : print(row)>
      <Updated(row) : print(row)>
      <Deleted(key) : print(key)>
    </onchange>
  </channel>

</program>
