${
  import { formFor } from 'scrml:data'

  type Address:struct = {
    street: string
    city:   string
  }

  type Signup:struct = {
    name:    string req length(>=2)
    address: Address
  }
}
<program>
  <formFor for=Signup>
    <slot name="address">
      <span>Address fields here</span>
    </slot>
  </formFor>
</program>
