type LoadError:enum = {
    NotFound(id: string)
        renders <div class="eb-notfound">Item ${id} not found</>
    Timeout
}

function loadItem(id: string)! LoadError {
    if (id == "missing") fail LoadError::NotFound(id)
    if (id == "slow") fail LoadError::Timeout
    return id
}

<page>
    <errorBoundary>
        ${loadItem("slow")}
    </>
</page>
