${
    type LoadError:enum = {
        NotFound
        Timeout
    }

    function loadThing(id: int)! LoadError {
        given id < 0 :> fail LoadError.NotFound
        return "ok"
    }

    function useIt(id: int) {
        return match loadThing(id) {
            ::NotFound :> "nf"
            ::Timeout :> "to"
        }
    }
}
<p>${useIt(1)}</>
