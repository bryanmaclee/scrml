<program>
type Book:enum = {
    Idle,
    Loaded(title: string, author: string, count: int)
}

<engine for=Book initial=.Idle>
    <Idle rule=.Loaded></>
    <Loaded title=t rule=.Idle>
        <p>${t}</p>
    </>
</>

<div class="library">
    <button onclick=${@book = Book.Loaded("t", "a", 1)}>Load</button>
</div>
</program>
