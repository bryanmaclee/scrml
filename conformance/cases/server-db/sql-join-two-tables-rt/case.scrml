${
    <list> = []
    function booksByAuthor(name: string) {
        return ?{`SELECT b.title AS title, a.name AS author FROM books b JOIN authors a ON a.id = b.author_id WHERE a.name = ${name} ORDER BY b.id`}.all()
    }
    function onLoad() {
        @list = booksByAuthor("Ada")
    }
}
<button id="load" onclick=onLoad()>Load books</>
<p if=@list id="l">loaded</>
