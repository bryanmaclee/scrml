<program db="./app.db">
${
    <updated> = []
    function bump(id: number, by: number) {
        return ?{`UPDATE items SET qty = qty + ${by} WHERE id = ${id} RETURNING id, qty`}.all()
    }
    function onBump() {
        @updated = bump(1, 3)
    }
}
<button id="go" onclick=onBump()>Bump qty</>
<p if=@updated id="u">bumped</>
</program>
