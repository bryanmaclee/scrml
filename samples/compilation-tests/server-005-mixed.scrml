// server-005-mixed.scrml
// Mixed server and client content. Tests: server func + client markup.

<program db="./articles.db">
<schema>
    ?{`CREATE TABLE articles (id INTEGER PRIMARY KEY, title TEXT)`}
</schema>
<div>
    ${
        server function loadData() {
            return ?{`SELECT title FROM articles LIMIT 5`}
        }
    }
    <h1>Articles</>
    <ul>
        <li>Article list goes here</>
    </ul>
</div>
</program>
