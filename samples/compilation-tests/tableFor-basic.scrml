${
    // §41.16 tableFor sample — minimal happy-path for the FOURTH L22 family member.
    //
    // Demonstrates:
    //   - Markup-element form `<tableFor for=T rows=@cell/>` (Form A per OQ-TF-1)
    //   - Mechanical title-case headers (id → "Id", email → "Email")
    //   - Type-driven per-cell default rendering (§41.16.6)
    //   - Empty rows source: <empty> default text fires per §41.16.9
    //
    // Compiles to canonical <table>/<thead>/<tbody> markup tree (Pillar 5
    // invariant per §41.16.11) — readable as if hand-authored.
    import { tableFor } from 'scrml:data'

    type User:struct = {
        id:    integer
        email: string req
        name:  string req
        role:  string req
    }
}

<program>
    <users> = [
        { id: 1, email: "alice@example.com", name: "Alice",   role: "Admin"  },
        { id: 2, email: "bob@example.com",   name: "Bob",     role: "Editor" },
        { id: 3, email: "carol@example.com", name: "Carol",   role: "Viewer" }
    ]

    <h1>Users</h1>
    <tableFor for=User rows=@users/>
</program>
