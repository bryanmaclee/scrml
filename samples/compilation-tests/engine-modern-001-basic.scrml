// engine-modern-001-basic — minimal §51.0 modern engine (state-children form).
//
// Modern form (§51.0.B + §51.0.F): state-children carry `rule=` attributes that
// declare the transition contract. SYM PASS 11 (B15) parses the body and fires
// `E-ENGINE-STATE-CHILD-MISSING` / `E-ENGINE-STATE-CHILD-INVALID-VARIANT`
// diagnostics; the TS-stage `parseMachineRules` no longer applies (it only
// owns the legacy §51.3 / §51.9 arrow-rule grammar).
//
// Per §51.0.C the engine auto-declares its reactive variable from `for=`
// (PhaseTag → @phaseTag); per §51.0.K the user does NOT separately declare it.
// Predecessor coverage was via `<engine name=X for=Y>` over a LEGACY arrow body
// (machine-002-traffic-light.scrml). This file is the first end-to-end positive
// case for the modern body shape — landed as part of the S75 fix for the
// false-positive `E-ENGINE-005` previously fired by `parseMachineRules` on
// state-child bodies.

${
    type PhaseTag:enum = { Idle, Loading, Done }
}

<engine for=PhaseTag initial=.Idle>
    <Idle rule=.Loading></>
    <Loading rule=.Done></>
    <Done rule=.Idle></>
</>

<program>
<div class="phase-app">
    <h1>Phase: ${@phaseTag.variant}</>
    <button onclick=${@phaseTag = PhaseTag.Loading}>Start</>
    <button onclick=${@phaseTag = PhaseTag.Done}>Finish</>
    <button onclick=${@phaseTag = PhaseTag.Idle}>Reset</>
</>
</program>
