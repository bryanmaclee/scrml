+    inExprRaw,
+    ofExprRaw,
+    asName,
+    keyExprRaw,
+    bodyChildren: children,
+    templateChildren,
+    emptyChild,
+    bodyRaw: "",
+    span: markupNode.span ?? null,
+  };
+}
