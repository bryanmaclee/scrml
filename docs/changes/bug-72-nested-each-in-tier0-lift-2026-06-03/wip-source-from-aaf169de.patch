+    const n = attr.name;
+    if (n === "in") inExprRaw = eachAttrRawText(attr.value);
+    else if (n === "of") ofExprRaw = eachAttrRawText(attr.value);
+    else if (n === "key") keyExprRaw = eachAttrRawText(attr.value);
+    else if (n === "as") asName = eachAttrRawText(attr.value);
